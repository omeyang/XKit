#!/usr/bin/env bash
# XKit commit-msg hook: 禁止 AI 署名进入提交信息。
#
# 禁止模式：
#   - Co-Authored-By: Claude ...
#   - Co-Authored-By: <任意含 noreply.anthropic.com>
#   - 🤖 Generated with [Claude Code]
#   - "Generated with Claude" / "Generated by Claude"
#   - 其他 Anthropic/Claude/Cursor/Copilot 的明显署名水印
#
# 启用：task install-hooks
# 跳过（不推荐）：git commit --no-verify

set -euo pipefail

msg_file="$1"
msg=$(cat "$msg_file")

# 去掉 git 自动添加的注释行后再匹配
content=$(grep -vE '^\s*#' "$msg_file" || true)

# 模式（不区分大小写）：AI 工具署名 / 协作标记 / 水印
# 说明：普通开发者 Co-Authored-By 人类是允许的，只拒绝匹配 AI 账号/名称的。
ai_pattern='(Co-Authored-By:\s*Claude|Co-Authored-By:.*noreply\.anthropic\.com|🤖\s*Generated with|Generated with \[?Claude|Generated by Claude|Co-Authored-By:.*\(Claude|Co-Authored-By:\s*Cursor|Co-Authored-By:.*github-copilot|Co-Authored-By:.*ChatGPT)'

if echo "$content" | grep -iEn "$ai_pattern"; then
  echo ""
  echo "❌ commit-msg: 提交信息包含 AI 署名，已拒绝"
  echo "   规则：XKit 提交信息不记录 AI 工具署名（Claude / Copilot / Cursor / ChatGPT 等）"
  echo "   处置：移除上述行后重新提交"
  exit 1
fi

exit 0
